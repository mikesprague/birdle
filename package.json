{
  "name": "birdle",
  "version": "1.22.1",
  "description": "birdle",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "changelog": "npx conventional-changelog -p conventionalcommits -n changelog.config.js -r 0 -i CHANGELOG.md -s && git add CHANGELOG.md",
    "changelog:preview": "npx conventional-changelog -p conventionalcommits -n changelog.config.js -u --stdout -i /dev/null",
    "clean": "rm -rf ./dist",
    "dev": "vite serve --port 3002",
    "start": "cross-env NODE_ENV=development npm run dev",
    "prebuild": "npm run clean && npm install",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1",
    "version": "npm run changelog"
  },
  "keywords": [],
  "repository": {
    "url": "https://github.com/mikesprague/birdle"
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "npm@11.11.0",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mikesprague/birdle/issues"
  },
  "homepage": "https://birdle.app",
  "dependencies": {
    "@rwh/keystrokes": "1.5.6",
    "@sweetalert2/theme-dark": "5.0.27",
    "balloons-js": "0.0.3",
    "clipboard": "2.0.11",
    "common-tags": "1.8.2",
    "cross-env": "10.1.0",
    "dayjs": "1.11.20",
    "emoji-blast": "0.11.0",
    "sweetalert2": "11.26.22"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@tailwindcss/vite": "4.2.1",
    "charts.css": "1.2.0",
    "conventional-changelog": "7.2.0",
    "conventional-changelog-cli": "5.0.0",
    "conventional-changelog-conventionalcommits": "9.3.0",
    "cz-git": "^1.12.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "stylelint": "17.4.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "4.2.1",
    "vite": "8.0.0",
    "vite-plugin-html": "3.2.2",
    "vite-plugin-pwa": "1.2.0"
  },
  "overrides": {
    "@conventional-changelog/git-client": "^2.6.0",
    "minimatch": "^10.2.4",
    "serialize-javascript": "^7.0.3"
  },
  "browserslist": {
    "development": [
      "last 1 version"
    ],
    "production": [
      "> 1%",
      "last 2 versions",
      "not ie <= 10"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "25.7.0",
    "npm": "11.11.0"
  }
}
