{
  "name": "birdle",
  "private": true,
  "version": "2.0.0-alpha.3",
  "description": "Birdle - A new BIRDLE every day",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "changelog": "npx conventional-changelog -p conventionalcommits -n changelog.config.js -r 0 -i CHANGELOG.md -s && git add CHANGELOG.md",
    "changelog:preview": "npx conventional-changelog -p conventionalcommits -n changelog.config.js -u --stdout -i /dev/null",
    "clean": "rm -rf ./dist",
    "dev": "vite serve --port 3002",
    "start": "cross-env NODE_ENV=development npm run dev",
    "prebuild": "npm run clean && npm install",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1",
    "version": "npm run changelog"
  },
  "keywords": [],
  "repository": {
    "url": "https://github.com/mikesprague/birdle"
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mikesprague/birdle/issues"
  },
  "homepage": "https://birdle.app",
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "npm@11.10.1",
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@rwh/keystrokes": "1.5.6",
    "balloons-js": "0.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dayjs": "1.11.19",
    "emoji-blast": "0.11.0",
    "lucide-react": "0.575.0",
    "next-themes": "0.4.6",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "6.1.1",
    "recharts": "2.15.4",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tinybase": "7.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@tailwindcss/vite": "4.2.0",
    "@types/node": "25.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "10.1.0",
    "conventional-changelog": "7.1.1",
    "conventional-changelog-cli": "5.0.0",
    "conventional-changelog-conventionalcommits": "9.1.0",
    "cz-git": "^1.12.0",
    "tailwindcss": "4.2.0",
    "terser": "5.46.0",
    "tw-animate-css": "1.4.0",
    "typescript": "~5.9.3",
    "vite": "7.3.1",
    "vite-plugin-pwa": "1.2.0"
  },
  "overrides": {
    "ajv": "8.18.0",
    "lodash": "4.17.23",
    "minimatch": "10.2.2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "25.6.1",
    "npm": "11.10.1"
  }
}
