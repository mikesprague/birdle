{
  "name": "birdle",
  "version": "1.23.1",
  "description": "birdle",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "changelog": "npx conventional-changelog -p conventionalcommits -n changelog.config.js -i CHANGELOG.md -s && git add CHANGELOG.md",
    "changelog:preview": "npx conventional-changelog -p conventionalcommits -n changelog.config.js -u --stdout -i /dev/null",
    "clean": "rm -rf ./dist",
    "copy:charts-css": "cp node_modules/charts.css/dist/charts.min.css public/charts.min.css",
    "dev": "vite serve --port 3002",
    "format": "npx oxfmt src",
    "format:check": "npx oxfmt --check src",
    "lint": "npx oxlint src",
    "start": "cross-env NODE_ENV=development npm run dev",
    "prebuild": "npm run clean && npm run copy:charts-css && npm install",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1",
    "version": "npm run changelog"
  },
  "keywords": [],
  "repository": {
    "url": "https://github.com/mikesprague/birdle"
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "npm@11.17.0",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mikesprague/birdle/issues"
  },
  "homepage": "https://birdle.app",
  "dependencies": {
    "@rwh/keystrokes": "1.5.6",
    "balloons-js": "0.0.3",
    "clipboard": "2.0.11",
    "common-tags": "1.8.2",
    "cross-env": "10.1.0",
    "dayjs": "1.11.21",
    "emoji-blast": "0.11.0",
    "sweetalert2": "11.26.25"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.1",
    "charts.css": "1.2.0",
    "conventional-changelog": "7.2.1",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "cz-git": "^1.13.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.70.0",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "stylelint": "17.13.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "4.3.1",
    "vite": "8.0.16",
    "vite-plugin-html": "3.2.2",
    "vite-plugin-pwa": "1.3.0"
  },
  "overrides": {
    "@conventional-changelog/git-client": "^2.7.0",
    "glob": "^13.0.6",
    "minimatch": "^10.2.5",
    "serialize-javascript": "^7.0.6"
  },
  "browserslist": {
    "development": [
      "last 1 version"
    ],
    "production": [
      "> 1%",
      "last 2 versions",
      "not ie <= 10"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "26.3.1",
    "npm": "11.17.0"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
